<script>
// ==================== STATE ====================
let myPrivKey = null, myPubKey = null, sharedKey = null, encMode = 'e2ee';

// ==================== TAB SWITCHING ====================
function switchTab(t) {
  ['keyx','enc','dec','meta'].forEach((id,i) => {
    document.getElementById('tab-'+id).classList.toggle('hidden', id !== t);
    document.querySelectorAll('.tab')[i].classList.toggle('active', id === t);
  });
}

// ==================== UTILS ====================
function b64(buf) { return btoa(String.fromCharCode(...new Uint8Array(buf))); }
function unb64(s) { const b=atob(s); const u=new Uint8Array(b.length); for(let i=0;i<b.length;i++)u[i]=b.charCodeAt(i); return u; }
function rand(n) { return crypto.getRandomValues(new Uint8Array(n)); }
function enc(s) { return new TextEncoder().encode(s); }
function dec(b) { return new TextDecoder().decode(b); }
async function copyEl(id) {
  const t = document.getElementById(id).textContent;
  await navigator.clipboard.writeText(t).catch(()=>{});
  const toast = document.getElementById('toast');
  toast.classList.add('show');
  setTimeout(()=>toast.classList.remove('show'), 1800);
}
function showHide(id, selector, msg) {
  const el = document.getElementById(id);
  el.classList.toggle('hidden', !selector);
  if (msg && selector) el.querySelector && (el.querySelector('[id$="-msg"]') || {}).textContent, el.textContent;
}
function setErr(prefix, msg) {
  document.getElementById(prefix+'-err').classList.remove('hidden');
  document.getElementById(prefix+'-err-msg').textContent = msg;
}
function clearErr(prefix) { document.getElementById(prefix+'-err').classList.add('hidden'); }
function togglePass(id, btn) {
  const el = document.getElementById(id);
  el.type = el.type === 'password' ? 'text' : 'password';
  btn.textContent = el.type === 'password' ? 'Show' : 'Hide';
}

// ==================== ECDH KEY PAIR ====================
async function generateKeyPair() {
  const pair = await crypto.subtle.generateKey({ name:'ECDH', namedCurve:'P-256' }, true, ['deriveKey','deriveBits']);
  myPrivKey = pair.privateKey; myPubKey = pair.publicKey;
  const pubJwk = await crypto.subtle.exportKey('jwk', myPubKey);
  const privJwk = await crypto.subtle.exportKey('jwk', myPrivKey);
  document.getElementById('out-pubkey').textContent = btoa(JSON.stringify(pubJwk));
  document.getElementById('out-privkey').textContent = btoa(JSON.stringify(privJwk));
  document.getElementById('keyx-result').classList.remove('hidden');
  // auto-set shared key if only one party (self-test mode with same key)
}

async function deriveShared() {
  document.getElementById('shared-ok').classList.add('hidden');
  document.getElementById('shared-err').classList.add('hidden');
  const raw = document.getElementById('contact-pubkey').value.trim();
  if (!raw) { document.getElementById('shared-err-msg').textContent = 'Please paste your contact\'s public key.'; document.getElementById('shared-err').classList.remove('hidden'); return; }
  if (!myPrivKey) { document.getElementById('shared-err-msg').textContent = 'Generate your own key pair first (Step 1).'; document.getElementById('shared-err').classList.remove('hidden'); return; }
  try {
    const jwk = JSON.parse(atob(raw));
    const contactPub = await crypto.subtle.importKey('jwk', jwk, { name:'ECDH', namedCurve:'P-256' }, false, []);
    sharedKey = await crypto.subtle.deriveKey(
      { name:'ECDH', public: contactPub },
      myPrivKey,
      { name:'AES-GCM', length:256 }, false, ['encrypt','decrypt']
    );
    document.getElementById('shared-ok').classList.remove('hidden');
    document.getElementById('enc-e2ee-info').classList.remove('hidden');
    document.getElementById('enc-e2ee-info').querySelector('span').textContent = '✅ Shared E2EE key derived from ECDH. No password needed.';
  } catch(e) {
    document.getElementById('shared-err-msg').textContent = 'Invalid public key format. Make sure you copied the full key without modification.';
    document.getElementById('shared-err').classList.remove('hidden');
  }
}

// ==================== ENCRYPT MODE ====================
function setMode(m) {
  encMode = m;
  document.getElementById('mode-e2ee').style.borderColor = m==='e2ee' ? 'var(--accent-dim)' : '';
  document.getElementById('mode-e2ee').style.color = m==='e2ee' ? 'var(--accent)' : '';
  document.getElementById('mode-pass').style.borderColor = m==='pass' ? 'var(--accent-dim)' : '';
  document.getElementById('mode-pass').style.color = m==='pass' ? 'var(--accent)' : '';
  document.getElementById('enc-e2ee-info').classList.toggle('hidden', m !== 'e2ee');
  document.getElementById('enc-pass-fields').classList.toggle('hidden', m !== 'pass');
}

function encCharCount() {
  const v = document.getElementById('enc-input').value;
  document.getElementById('enc-chars').textContent = v.length + ' chars';
}

// ==================== PADDING ====================
function padMsg(plainBytes, blockSize=256) {
  const padLen = blockSize - ((plainBytes.length + 1) % blockSize);
  const padded = new Uint8Array(plainBytes.length + 1 + padLen);
  padded.set(plainBytes);
  padded[plainBytes.length] = 0x80; // ISO 7816-4 padding marker
  return padded;
}
function unpadMsg(padded) {
  for (let i = padded.length - 1; i >= 0; i--) {
    if (padded[i] === 0x80) return padded.slice(0, i);
  }
  return padded;
}

// ==================== PBKDF2 ====================
async function pbkdf2Key(password, salt) {
  const km = await crypto.subtle.importKey('raw', enc(password), 'PBKDF2', false, ['deriveKey']);
  return crypto.subtle.deriveKey({ name:'PBKDF2', salt, iterations:310000, hash:'SHA-256' }, km, { name:'AES-GCM', length:256 }, false, ['encrypt','decrypt']);
}

// ==================== ENCRYPT ====================
async function encryptMsg() {
  clearErr('enc');
  document.getElementById('enc-out-wrap').classList.add('hidden');
  const plaintext = document.getElementById('enc-input').value;
  if (!plaintext.trim()) { setErr('enc','Please enter a message to encrypt.'); return; }

  const pad = document.getElementById('pad-toggle').checked;
  let plainBytes = enc(plaintext);
  if (pad) plainBytes = padMsg(plainBytes);

  try {
    let key, prefix;
    if (encMode === 'e2ee') {
      if (!sharedKey) { setErr('enc','No E2EE shared key found. Complete key exchange in the E2EE Keys tab first, or switch to Password mode.'); return; }
      key = sharedKey; prefix = 'PS1E:';
    } else {
      const pass = document.getElementById('enc-pass').value;
      if (pass.length < 6) { setErr('enc','Password must be at least 6 characters.'); return; }
      const salt = rand(16);
      key = await pbkdf2Key(pass, salt);
      const iv2 = rand(12);
      const ct = await crypto.subtle.encrypt({ name:'AES-GCM', iv:iv2 }, key, plainBytes);
      const out = new Uint8Array(1 + 16 + 12 + ct.byteLength);
      out[0] = pad ? 1 : 0;
      out.set(salt, 1); out.set(iv2, 17);
      out.set(new Uint8Array(ct), 29);
      document.getElementById('enc-out').textContent = 'PS1P:' + b64(out.buffer);
      document.getElementById('enc-out-wrap').classList.remove('hidden');
      return;
    }
    const iv = rand(12);
    const ct = await crypto.subtle.encrypt({ name:'AES-GCM', iv }, key, plainBytes);
    const out = new Uint8Array(1 + 12 + ct.byteLength);
    out[0] = pad ? 1 : 0;
    out.set(iv, 1);
    out.set(new Uint8Array(ct), 13);
    document.getElementById('enc-out').textContent = prefix + b64(out.buffer);
    document.getElementById('enc-out-wrap').classList.remove('hidden');
  } catch(e) { setErr('enc', 'Encryption failed: ' + e.message); }
}

// ==================== DECRYPT ====================
async function decryptMsg() {
  clearErr('dec');
  document.getElementById('dec-out-wrap').classList.add('hidden');
  const cipher = document.getElementById('dec-input').value.trim();
  if (!cipher) { setErr('dec','Please paste an encrypted message.'); return; }

  try {
    if (cipher.startsWith('PS1E:')) {
      if (!sharedKey) { setErr('dec','No E2EE shared key. Complete key exchange in the E2EE Keys tab first.'); return; }
      const bytes = unb64(cipher.slice(5));
      const padded = bytes[0] === 1;
      const iv = bytes.slice(1, 13);
      const ct = bytes.slice(13);
      const plain = await crypto.subtle.decrypt({ name:'AES-GCM', iv }, sharedKey, ct);
      const result = padded ? unpadMsg(new Uint8Array(plain)) : new Uint8Array(plain);
      document.getElementById('dec-out').textContent = dec(result);
      document.getElementById('dec-out-wrap').classList.remove('hidden');
    } else if (cipher.startsWith('PS1P:')) {
      const pass = document.getElementById('dec-pass').value;
      if (!pass) { setErr('dec','This is a password-encrypted message. Please enter the password.'); return; }
      const bytes = unb64(cipher.slice(5));
      const padded = bytes[0] === 1;
      const salt = bytes.slice(1, 17);
      const iv = bytes.slice(17, 29);
      const ct = bytes.slice(29);
      const key = await pbkdf2Key(pass, salt);
      const plain = await crypto.subtle.decrypt({ name:'AES-GCM', iv }, key, ct);
      const result = padded ? unpadMsg(new Uint8Array(plain)) : new Uint8Array(plain);
      document.getElementById('dec-out').textContent = dec(result);
      document.getElementById('dec-out-wrap').classList.remove('hidden');
    } else {
      setErr('dec','Unrecognised format. Message must start with PS1E: (E2EE) or PS1P: (password).');
    }
  } catch(e) { setErr('dec','Decryption failed. Wrong key/password or corrupted message.'); }
}

// ==================== METADATA ANALYZER ====================
const META_PATTERNS = [
  { id:'email',    label:'Email address',    regex:/\b[\w.+-]+@[\w-]+\.[a-z]{2,}\b/gi,                     risk:'high',  advice:'Remove or replace with a pseudonym. Real email addresses uniquely identify you.' },
  { id:'phone',    label:'Phone number',     regex:/(\+?\d[\d\s\-().]{6,}\d)/g,                             risk:'high',  advice:'Replace with a code word agreed in advance.' },
  { id:'url',      label:'URL / domain',     regex:/https?:\/\/[^\s]+|www\.[^\s]+/gi,                       risk:'med',   advice:'URLs may contain tracking parameters or reveal browsing history.' },
  { id:'ip',       label:'IP address',       regex:/\b(\d{1,3}\.){3}\d{1,3}\b/g,                            risk:'high',  advice:'IP addresses can reveal your location and ISP.' },
  { id:'fullname', label:'Full name pattern',regex:/\b([A-Z][a-z]+\s[A-Z][a-z]+)\b/g,                      risk:'med',   advice:'Names in messages can link encrypted content back to real identities.' },
  { id:'location', label:'Street / address', regex:/\b\d+\s+[A-Z][a-z]+\s+(Street|St|Road|Rd|Avenue|Ave|Lane|Ln|Drive|Dr|Boulevard|Blvd)\b/gi, risk:'high', advice:'Physical addresses are strong identifiers.' },
  { id:'postcode', label:'Postcode / ZIP',   regex:/\b([A-Z]{1,2}\d{1,2}[A-Z]?\s*\d[A-Z]{2}|\d{5}(-\d{4})?)\b/g, risk:'high', advice:'Postcodes can pinpoint your location.' },
  { id:'date',     label:'Specific date',    regex:/\b\d{1,2}[\/\-]\d{1,2}[\/\-]\d{2,4}\b/g,              risk:'low',   advice:'Specific dates may correlate with known events and narrow down authorship.' },
];

function analyzeMetadata() {
  const text = document.getElementById('meta-input').value;
  document.getElementById('meta-ok').classList.add('hidden');
  document.getElementById('meta-results').classList.add('hidden');
  if (!text.trim()) return;

  let found = [];
  META_PATTERNS.forEach(p => {
    const matches = [...text.matchAll(p.regex)];
    if (matches.length) found.push({ ...p, matches: [...new Set(matches.map(m=>m[0]))] });
  });

  if (found.length === 0) {
    document.getElementById('meta-ok').classList.remove('hidden');
    return;
  }

  const summary = document.getElementById('meta-summary');
  const high = found.filter(f=>f.risk==='high').length;
  summary.innerHTML = `<div class="alert ${high>0?'a-err':found.length>0?'a-warn':'a-ok'}" style="margin-bottom:0.75rem;">
    <span>${high>0?'⛔':'⚠'} Found <strong>${found.length} type${found.length>1?'s':''}</strong> of metadata risk 
    (${found.filter(f=>f.risk==='high').length} high, ${found.filter(f=>f.risk==='med').length} medium, ${found.filter(f=>f.risk==='low').length} low). 
    Consider removing or replacing before encrypting.</span></div>`;

  const list = document.getElementById('meta-risk-list');
  list.innerHTML = found.map(f => `
    <div class="risk-item ${f.risk}">
      <span class="risk-badge ${f.risk}">${f.risk.toUpperCase()}</span>
      <div class="risk-text">
        <strong>${f.label}</strong>
        Detected: <code style="font-family:'DM Mono',monospace;font-size:11.5px;">${f.matches.slice(0,3).join(', ')}${f.matches.length>3?' … +' + (f.matches.length-3) + ' more':''}</code>
        <br><span style="color:var(--muted);font-size:12px;">${f.advice}</span>
      </div>
    </div>`).join('');

  // Build redacted text
  let clean = text;
  META_PATTERNS.forEach(p => {
    clean = clean.replace(p.regex, m => '[REDACTED-' + p.label.toUpperCase().replace(/ /g,'_') + ']');
  });
  document.getElementById('meta-clean').textContent = clean;
  document.getElementById('meta-results').classList.remove('hidden');
}

function autoRedact() {
  let text = document.getElementById('meta-input').value;
  META_PATTERNS.forEach(p => {
    text = text.replace(p.regex, m => '[REDACTED]');
  });
  document.getElementById('meta-input').value = text;
  analyzeMetadata();
}

function runMetaCheck(sourceId) {
  switchTab('meta');
  const src = document.getElementById(sourceId);
  if (src) document.getElementById('meta-input').value = src.textContent || src.value || '';
}

// ==================== PASSWORD STRENGTH ====================
function checkStrength(p) {
  const fill = document.getElementById('str-fill'), note = document.getElementById('str-note');
  let s = 0;
  if (p.length >= 8) s++; if (p.length >= 16) s++;
  if (/[A-Z]/.test(p)) s++; if (/[0-9]/.test(p)) s++; if (/[^A-Za-z0-9]/.test(p)) s++;
  const lvl = p.length===0 ? 0 : Math.min(s,5);
  const cfg = [{w:'0%',c:'',t:'Enter a password'},{w:'20%',c:'#f05a50',t:'Very weak'},{w:'45%',c:'#e8a020',t:'Fair — add numbers or symbols'},{w:'65%',c:'#e8a020',t:'Moderate'},{w:'85%',c:'#3ec870',t:'Strong'},{w:'100%',c:'#38c9a0',t:'Very strong ✓'}];
  fill.style.width = cfg[lvl].w; fill.style.background = cfg[lvl].c; note.textContent = cfg[lvl].t;
}

// init
setMode('e2ee');
document.getElementById('dec-pass-field') && document.getElementById('dec-pass-field').classList.remove('hidden');
</script>
