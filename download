def cmd_keygen(args):
    head("ECDH Key Pair Generation (OpenSSL / P-256)")
    priv, pub = generate_keypair()
    password  = None

    if args.protect:
        pw1 = getpass.getpass("  Enter password to protect private key: ")
        pw2 = getpass.getpass("  Confirm password: ")
        if pw1 != pw2:
            err("Passwords do not match.")
            sys.exit(1)
        password = pw1.encode()

    save_keypair(priv, pub, args.output, password)
    fp = fingerprint(pub)
    info(f"Key fingerprint: {C.BOLD}{fp}{C.RESET}")
    info("Share your fingerprint through a trusted channel to prevent MITM attacks.")


def cmd_fingerprint(args):
    head("Key Fingerprint")
    with open(args.key, "r") as f:
        pem = f.read()
    pub = load_public_key(pem)
    fp  = fingerprint(pub)
    print(f"\n  {C.BOLD}{C.CYAN}{fp}{C.RESET}\n")
    info("Compare this with your contact's fingerprint by phone or in person.")


def cmd_encrypt(args):
    head("Encryption (AES-256-GCM via OpenSSL)")

    if args.file:
        with open(args.file, "r", encoding="utf-8") as f:
            message = f.read()
    else:
        message = args.message or input("  Message: ")

    # Metadata check first
    result = run_metadata_check(message)
    if result["findings"]:
        warn("Metadata risks detected in your message:")
        for label, data in result["findings"].items():
            risk_color = C.RED if data["risk"] == "HIGH" else C.YELLOW if data["risk"] == "MEDIUM" else C.GREEN
            print(f"  {risk_color}[{data['risk']}]{C.RESET} {label}: {', '.join(data['matches'][:3])}")
        print()
        choice = input("  Use auto-redacted version? [y/N]: ").strip().lower()
        if choice == "y":
            message = result["redacted"]
            ok("Using redacted message.")

    no_pad = getattr(args, "no_pad", False)
    apply_padding = not no_pad

    if args.mode == "e2ee":
        with open(args.their_pubkey, "r") as f:
            peer_pem = f.read()
        with open(args.my_privkey, "r") as f:
            my_pem = f.read()
        password_bytes = None
        if args.key_password:
            password_bytes = getpass.getpass("  Private key password: ").encode()
        priv_key = load_private_key(my_pem, password_bytes)
        peer_pub = load_public_key(peer_pem)
        shared   = derive_shared_secret(priv_key, peer_pub)
        ct       = encrypt_e2ee(message, shared, apply_padding)
        ok(f"Encrypted with ECDH E2EE (PBKDF2 + AES-256-GCM / OpenSSL)")
    else:
        pw = getpass.getpass("  Encryption password: ")
        ct = encrypt_password(message, pw, apply_padding)
        ok(f"Encrypted with PBKDF2-SHA256 + AES-256-GCM ({PBKDF2_ITERATIONS:,} iterations / OpenSSL)")

    if args.output_file:
        with open(args.output_file, "w") as f:
            f.write(ct)
        ok(f"Ciphertext saved to: {args.output_file}")
    else:
        print(f"\n{C.DIM}{ct}{C.RESET}\n")


def cmd_decrypt(args):
    head("Decryption (AES-256-GCM via OpenSSL)")

    if args.file:
        with open(args.file, "r") as f:
            ciphertext = f.read().strip()
    else:
        ciphertext = args.ciphertext or input("  Ciphertext: ").strip()

    if ciphertext.startswith("PS1E:"):
        with open(args.my_privkey, "r") as f:
            my_pem = f.read()
        with open(args.their_pubkey, "r") as f:
            peer_pem = f.read()
        password_bytes = None
        if args.key_password:
            password_bytes = getpass.getpass("  Private key password: ").encode()
        priv_key  = load_private_key(my_pem, password_bytes)
        peer_pub  = load_public_key(peer_pem)
        shared    = derive_shared_secret(priv_key, peer_pub)
        plaintext = decrypt_e2ee(ciphertext, shared)
        ok("Decrypted using ECDH shared key (AES-256-GCM / OpenSSL)")
    elif ciphertext.startswith("PS1P:"):
        pw        = getpass.getpass("  Decryption password: ")
        plaintext = decrypt_password(ciphertext, pw)
        ok("Decrypted using PBKDF2 password key (AES-256-GCM / OpenSSL)")
    else:
        err("Unknown format. Message must start with PS1E: or PS1P:")
        sys.exit(1)

    print(f"\n{C.GREEN}Plaintext:{C.RESET}\n{plaintext}\n")

    if args.check_metadata:
        result = run_metadata_check(plaintext)
        if result["findings"]:
            warn("Metadata found in decrypted message:")
            for label, data in result["findings"].items():
                risk_color = C.RED if data["risk"] == "HIGH" else C.YELLOW
                print(f"  {risk_color}[{data['risk']}]{C.RESET} {label}: {', '.join(data['matches'][:3])}")


def cmd_metadata(args):
    head("Metadata Analyzer")

    if args.file:
        with open(args.file, "r", encoding="utf-8") as f:
            text = f.read()
    else:
        text = args.text or input("  Paste message text:\n> ")

    result = run_metadata_check(text)

    if not result["findings"]:
        ok("No metadata risks detected. Message appears clean.")
        return

    high = sum(1 for v in result["findings"].values() if v["risk"] == "HIGH")
    med  = sum(1 for v in result["findings"].values() if v["risk"] == "MEDIUM")
    low  = sum(1 for v in result["findings"].values() if v["risk"] == "LOW")

    warn(f"Found {len(result['findings'])} risk type(s): {high} HIGH, {med} MEDIUM, {low} LOW\n")

    for label, data in result["findings"].items():
        risk_color = C.RED if data["risk"] == "HIGH" else C.YELLOW if data["risk"] == "MEDIUM" else C.GREEN
        matches_str = ", ".join(f'"{m}"' for m in data["matches"][:3])
        if len(data["matches"]) > 3:
            matches_str += f" ... +{len(data['matches']) - 3} more"
        print(f"  {risk_color}[{data['risk']:6s}]{C.RESET} {label:<25} {C.DIM}{matches_str}{C.RESET}")

    if args.redact:
        print(f"\n{C.CYAN}Redacted version:{C.RESET}")
        print(result["redacted"])
        if args.output_file:
            with open(args.output_file, "w") as f:
                f.write(result["redacted"])
            ok(f"Redacted version saved to: {args.output_file}")


def cmd_gpg(args):
    head("GnuPG Integration")
    if not GPG_AVAILABLE:
        err("python-gnupg not installed. Run: pip3 install python-gnupg")
        sys.exit(1)

    mgr = GPGManager()

    if args.gpg_action == "genkey":
        name   = args.name  or input("  Full name: ")
        email  = args.email or input("  Email: ")
        pw     = getpass.getpass("  GPG key passphrase: ")
        info("Generating 4096-bit RSA GPG key pair...")
        fp = mgr.generate_gpg_key(name, email, pw)
        ok(f"GPG key generated. Fingerprint: {fp}")

    elif args.gpg_action == "list":
        keys = mgr.list_keys(secret=args.secret)
        if not keys:
            info("No keys found in keyring.")
            return
        for k in keys:
            uids = ", ".join(k.get("uids", []))
            print(f"  {C.CYAN}{k['fingerprint']}{C.RESET}  {uids}")

    elif args.gpg_action == "export":
        pub_key = mgr.export_public_key_gpg(args.fingerprint)
        if args.output_file:
            with open(args.output_file, "w") as f:
                f.write(pub_key)
            ok(f"GPG public key exported to: {args.output_file}")
        else:
            print(pub_key)

    elif args.gpg_action == "import":
        with open(args.key_file, "r") as f:
            key_data = f.read()
        result = mgr.import_public_key_gpg(key_data)
        ok(f"Imported {result['imported']} key(s): {result['fingerprints']}")

    elif args.gpg_action == "encrypt":
        message = input("  Message to encrypt:\n> ")
        ct = mgr.encrypt_gpg(message, args.recipient)
        if args.output_file:
            with open(args.output_file, "w") as f:
                f.write(ct)
            ok(f"GPG-encrypted message saved to: {args.output_file}")
        else:
            print(ct)

    elif args.gpg_action == "decrypt":
        with open(args.file, "r") as f:
            ct = f.read()
        pw = getpass.getpass("  GPG passphrase: ")
        plaintext = mgr.decrypt_gpg(ct, pw)
        print(f"\n{C.GREEN}Decrypted:{C.RESET}\n{plaintext}\n")

    elif args.gpg_action == "sign":
        message = input("  Message to sign:\n> ")
        pw = getpass.getpass("  GPG passphrase: ")
        signed = mgr.sign_message(message, args.fingerprint, pw)
        if args.output_file:
            with open(args.output_file, "w") as f:
                f.write(signed)
            ok(f"Signed message saved to: {args.output_file}")

    elif args.gpg_action == "verify":
        with open(args.file, "r") as f:
            signed = f.read()
        result = mgr.verify_signature(signed)
        if result["valid"]:
            ok(f"Signature VALID")
            info(f"Signed by : {result['username']}")
            info(f"Fingerprint: {result['fingerprint']}")
            info(f"Trust level: {result['trust_level']}")
        else:
            err("Signature INVALID or unverified.")


# ─────────────────────────────────────────────
# ARGUMENT PARSER
# ─────────────────────────────────────────────

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="privacyshield",
        description="PrivacyShield v3 — usable E2EE and metadata protection (Python/OpenSSL/GnuPG)"
    )
    sub = p.add_subparsers(dest="command")

    # keygen
    kg = sub.add_parser("keygen", help="Generate an ECDH P-256 key pair (OpenSSL)")
    kg.add_argument("-o", "--output",  default="./keys", help="Directory to save key files")
    kg.add_argument("--protect",       action="store_true", help="Password-protect the private key")

    # fingerprint
    fp_p = sub.add_parser("fingerprint", help="Compute SHA-256 fingerprint of a public key")
    fp_p.add_argument("key", help="Path to public key PEM file")

    # encrypt
    en = sub.add_parser("encrypt", help="Encrypt a message (E2EE or password)")
    en.add_argument("-m", "--message",      help="Message string to encrypt")
    en.add_argument("-f", "--file",         help="File containing the message")
    en.add_argument("-o", "--output-file",  help="Write ciphertext to file")
    en.add_argument("--mode",              choices=["e2ee","password"], default="e2ee")
    en.add_argument("--my-privkey",        help="Your private key PEM (E2EE mode)")
    en.add_argument("--their-pubkey",      help="Recipient public key PEM (E2EE mode)")
    en.add_argument("--key-password",      action="store_true", help="Private key is password-protected")
    en.add_argument("--no-pad",            action="store_true", help="Disable ISO/IEC 7816-4 padding")

    # decrypt
    de = sub.add_parser("decrypt", help="Decrypt a message")
    de.add_argument("-c", "--ciphertext",   help="Ciphertext string")
    de.add_argument("-f", "--file",         help="File containing ciphertext")
    de.add_argument("--my-privkey",        help="Your private key PEM (E2EE mode)")
    de.add_argument("--their-pubkey",      help="Sender public key PEM (E2EE mode)")
    de.add_argument("--key-password",      action="store_true")
    de.add_argument("--check-metadata",    action="store_true", help="Scan decrypted text for PII")

    # metadata
    mt = sub.add_parser("metadata", help="Scan text for personally identifying information")
    mt.add_argument("-t", "--text",         help="Text string to analyse")
    mt.add_argument("-f", "--file",         help="File to analyse")
    mt.add_argument("-r", "--redact",       action="store_true", help="Print redacted version")
    mt.add_argument("-o", "--output-file",  help="Save redacted version to file")

    # gpg
    gp = sub.add_parser("gpg", help="GnuPG key management and encryption")
    gp.add_argument("gpg_action",
                    choices=["genkey","list","export","import","encrypt","decrypt","sign","verify"])
    gp.add_argument("--name",         help="Name for key generation")
    gp.add_argument("--email",        help="Email for key generation")
    gp.add_argument("--fingerprint",  help="GPG key fingerprint")
    gp.add_argument("--recipient",    help="Recipient fingerprint for encryption")
    gp.add_argument("--key-file",     help="Key file for import")
    gp.add_argument("--file", "-f",   help="Input file")
    gp.add_argument("--output-file",  help="Output file")
    gp.add_argument("--secret",       action="store_true", help="List secret keys")

    return p


def main():
    banner()
    parser = build_parser()
    args   = parser.parse_args()

    dispatch = {
        "keygen":      cmd_keygen,
        "fingerprint": cmd_fingerprint,
        "encrypt":     cmd_encrypt,
        "decrypt":     cmd_decrypt,
        "metadata":    cmd_metadata,
        "gpg":         cmd_gpg,
    }

    if args.command not in dispatch:
        parser.print_help()
        sys.exit(0)

    dispatch[args.command](args)


if __name__ == "__main__":
    main()
