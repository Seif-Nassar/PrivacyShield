# ─────────────────────────────────────────────
# KEY MANAGEMENT (ECDH via OpenSSL)
# ─────────────────────────────────────────────

def generate_keypair() -> tuple:
    """
    Generate an ECDH P-256 key pair using OpenSSL (via cryptography library).
    Returns (private_key, public_key) as cryptography objects.
    """
    private_key = generate_private_key(SECP256R1(), default_backend())
    public_key  = private_key.public_key()
    return private_key, public_key


def export_public_key(public_key: EllipticCurvePublicKey) -> str:
    """Serialise public key to PEM format (OpenSSL standard)."""
    pem = public_key.public_bytes(
        encoding=serialization.Encoding.PEM,
        format=serialization.PublicFormat.SubjectPublicKeyInfo
    )
    return pem.decode()


def export_private_key(private_key: EllipticCurvePrivateKey, password: bytes = None) -> str:
    """
    Serialise private key to PEM format, optionally encrypted with AES-256-CBC.
    Using password=None stores it unencrypted (not recommended for production).
    """
    encryption = (
        serialization.BestAvailableEncryption(password)
        if password else
        serialization.NoEncryption()
    )
    pem = private_key.private_bytes(
        encoding=serialization.Encoding.PEM,
        format=serialization.PrivateFormat.PKCS8,
        encryption_algorithm=encryption
    )
    return pem.decode()


def load_public_key(pem_str: str) -> EllipticCurvePublicKey:
    """Load a PEM public key (OpenSSL format)."""
    return serialization.load_pem_public_key(pem_str.encode(), backend=default_backend())


def load_private_key(pem_str: str, password: bytes = None) -> EllipticCurvePrivateKey:
    """Load a PEM private key, decrypting if a password is provided."""
    return serialization.load_pem_private_key(
        pem_str.encode(), password=password, backend=default_backend()
    )


def save_keypair(private_key, public_key, output_dir: str, password: bytes = None):
    """Save key pair as PEM files in output_dir."""
    os.makedirs(output_dir, exist_ok=True)
    pub_path  = os.path.join(output_dir, "public_key.pem")
    priv_path = os.path.join(output_dir, "private_key.pem")
    with open(pub_path,  "w") as f:
        f.write(export_public_key(public_key))
    with open(priv_path, "w") as f:
        f.write(export_private_key(private_key, password))
    ok(f"Public key saved  : {pub_path}")
    ok(f"Private key saved : {priv_path}")
    if password:
        ok("Private key is password-protected (AES-256-CBC)")


def derive_shared_secret(private_key, peer_public_key) -> bytes:
    """
    Perform ECDH key agreement using OpenSSL.
    Returns 32 raw bytes of shared secret material.
    """
    shared_key_material = private_key.exchange(ECDH(), peer_public_key)
    # Derive a proper AES-256 key from the raw shared material using HKDF
    from cryptography.hazmat.primitives.kdf.hkdf import HKDF
    hkdf = HKDF(
        algorithm=hashes.SHA256(),
        length=32,
        salt=None,
        info=b"PrivacyShield-v3-ECDH",
        backend=default_backend()
    )
    return hkdf.derive(shared_key_material)


def fingerprint(public_key) -> str:
    """
    Compute SHA-256 fingerprint of a public key.
    Displayed as colon-separated hex pairs (OpenSSL style).
    """
    pub_bytes = public_key.public_bytes(
        encoding=serialization.Encoding.DER,
        format=serialization.PublicFormat.SubjectPublicKeyInfo
    )
    digest = hashes.Hash(hashes.SHA256(), backend=default_backend())
    digest.update(pub_bytes)
    raw = digest.finalize()
    return ":".join(f"{b:02X}" for b in raw)


# ─────────────────────────────────────────────
# PADDING (ISO/IEC 7816-4)
# ─────────────────────────────────────────────

def pad(data: bytes, block_size: int = PAD_BLOCK) -> bytes:
    """Apply ISO/IEC 7816-4 padding to hide true message length."""
    pad_len = block_size - ((len(data) + 1) % block_size)
    return data + b"\x80" + (b"\x00" * pad_len)


def unpad(data: bytes) -> bytes:
    """Strip ISO/IEC 7816-4 padding after decryption."""
    idx = len(data) - 1
    while idx >= 0:
        if data[idx] == 0x80:
            return data[:idx]
        if data[idx] != 0x00:
            break
        idx -= 1
    return data


# ─────────────────────────────────────────────
# SYMMETRIC ENCRYPTION (AES-256-GCM via OpenSSL)
# ─────────────────────────────────────────────

def derive_key_from_password(password: str, salt: bytes) -> bytes:
    """
    Derive a 256-bit AES key from a password using PBKDF2-HMAC-SHA256.
    Uses OpenSSL's PBKDF2 implementation via the cryptography library.
    """
    kdf = PBKDF2HMAC(
        algorithm=hashes.SHA256(),
        length=32,
        salt=salt,
        iterations=PBKDF2_ITERATIONS,
        backend=default_backend()
    )
    return kdf.derive(password.encode())


def aes_encrypt(key: bytes, plaintext: bytes, apply_padding: bool = True) -> bytes:
    """
    Encrypt plaintext using AES-256-GCM (OpenSSL backend).
    Output format: [1-byte pad_flag][12-byte IV][ciphertext+tag]
    """
    if apply_padding:
        plaintext = pad(plaintext)

    iv  = os.urandom(IV_BYTES)
    aes = AESGCM(key)
    ct  = aes.encrypt(iv, plaintext, None)  # None = no AAD
    pad_flag = b"\x01" if apply_padding else b"\x00"
    return pad_flag + iv + ct


def aes_decrypt(key: bytes, payload: bytes) -> bytes:
    """
    Decrypt AES-256-GCM ciphertext.
    Raises InvalidTag if the ciphertext has been tampered with.
    """
    pad_flag = payload[0]
    iv       = payload[1:13]
    ct       = payload[13:]
    aes      = AESGCM(key)
    plaintext = aes.decrypt(iv, ct, None)
    if pad_flag == 1:
        plaintext = unpad(plaintext)
    return plaintext


# ─────────────────────────────────────────────
# HIGH-LEVEL ENCRYPT / DECRYPT
# ─────────────────────────────────────────────

def encrypt_e2ee(message: str, shared_key: bytes, apply_padding: bool = True) -> str:
    """
    Encrypt a message using the ECDH-derived shared key.
    Returns a PS1E: prefixed base64 string.
    """
    payload = aes_encrypt(shared_key, message.encode("utf-8"), apply_padding)
    return VERSION_E2EE.decode() + base64.b64encode(payload).decode()


def decrypt_e2ee(ciphertext: str, shared_key: bytes) -> str:
    """Decrypt a PS1E: message using the ECDH-derived shared key."""
    if not ciphertext.startswith(VERSION_E2EE.decode()):
        raise ValueError("Not a valid PS1E: message.")
    payload = base64.b64decode(ciphertext[5:])
    return aes_decrypt(shared_key, payload).decode("utf-8")


def encrypt_password(message: str, password: str, apply_padding: bool = True) -> str:
    """
    Encrypt a message using a password (PBKDF2 + AES-256-GCM via OpenSSL).
    Returns a PS1P: prefixed base64 string.
    """
    salt    = os.urandom(SALT_BYTES)
    key     = derive_key_from_password(password, salt)
    payload = aes_encrypt(key, message.encode("utf-8"), apply_padding)
    # Prepend salt so it can be recovered at decryption time
    return VERSION_PASS.decode() + base64.b64encode(salt + payload).decode()


def decrypt_password(ciphertext: str, password: str) -> str:
    """Decrypt a PS1P: message using the original password."""
    if not ciphertext.startswith(VERSION_PASS.decode()):
        raise ValueError("Not a valid PS1P: message.")
    raw     = base64.b64decode(ciphertext[5:])
    salt    = raw[:SALT_BYTES]
    payload = raw[SALT_BYTES:]
    key     = derive_key_from_password(password, salt)
    return aes_decrypt(key, payload).decode("utf-8")


