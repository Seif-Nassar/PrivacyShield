PBKDF2_ITERATIONS = 310_000   # OWASP 2023 recommendation
SALT_BYTES        = 16        # 128-bit random salt
IV_BYTES          = 12        # 96-bit GCM nonce
PAD_BLOCK         = 256       # ISO/IEC 7816-4 padding block size
VERSION_E2EE      = b"PS1E:"
VERSION_PASS      = b"PS1P:"

