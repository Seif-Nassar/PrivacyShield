# GNUPG INTEGRATION
# ─────────────────────────────────────────────

class GPGManager:
    """
    Wraps python-gnupg to provide a usable interface for key management
    and alternative GPG-based encryption alongside the ECDH path.
    """

    def __init__(self, gpg_home: str = None):
        if not GPG_AVAILABLE:
            raise RuntimeError(
                "python-gnupg is not installed. Run: pip3 install python-gnupg"
            )
        self.gpg = gnupg.GPG(gnupghome=gpg_home or os.path.expanduser("~/.gnupg"))

    def list_keys(self, secret: bool = False) -> list:
        """Return all keys in the GPG keyring."""
        return self.gpg.list_keys(secret)

    def generate_gpg_key(self, name: str, email: str, passphrase: str) -> str:
        """
        Generate a GPG key pair for identity management.
        Returns the fingerprint of the new key.
        """
        input_data = self.gpg.gen_key_input(
            key_type="RSA",
            key_length=4096,
            name_real=name,
            name_email=email,
            passphrase=passphrase,
            expire_date="2y"
        )
        result = self.gpg.gen_key(input_data)
        return str(result.fingerprint)

    def export_public_key_gpg(self, fingerprint: str) -> str:
        """Export a GPG public key as ASCII-armoured text."""
        return self.gpg.export_keys(fingerprint)

    def import_public_key_gpg(self, key_data: str) -> dict:
        """Import a GPG public key from ASCII-armoured text."""
        result = self.gpg.import_keys(key_data)
        return {"imported": result.count, "fingerprints": result.fingerprints}

    def encrypt_gpg(self, message: str, recipient_fingerprint: str) -> str:
        """
        Encrypt a message to a GPG recipient.
        Uses the recipient's public key from the keyring.
        """
        result = self.gpg.encrypt(message, recipient_fingerprint, always_trust=True)
        if not result.ok:
            raise RuntimeError(f"GPG encryption failed: {result.status}")
        return str(result)

    def decrypt_gpg(self, ciphertext: str, passphrase: str) -> str:
        """Decrypt a GPG-encrypted message using the private key passphrase."""
        result = self.gpg.decrypt(ciphertext, passphrase=passphrase)
        if not result.ok:
            raise RuntimeError(f"GPG decryption failed: {result.status}")
        return str(result)

    def sign_message(self, message: str, key_fingerprint: str, passphrase: str) -> str:
        """Sign a message with a GPG private key for non-repudiation."""
        result = self.gpg.sign(message, keyid=key_fingerprint, passphrase=passphrase)
        return str(result)

    def verify_signature(self, signed_message: str) -> dict:
        """Verify a GPG signature. Returns dict with trust level and signer info."""
        result = self.gpg.verify(signed_message)
        return {
            "valid":       result.valid,
            "fingerprint": result.fingerprint,
            "username":    result.username,
            "trust_level": result.trust_level,
            "timestamp":   result.timestamp,
        }


